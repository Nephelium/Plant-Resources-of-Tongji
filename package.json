{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:dynamic": "vue-tsc -b && vite build --mode dynamic",
    "build:static": "vue-tsc -b && vite build --mode static",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "vue-tsc --noEmit"
  },
  "dependencies": {
    "fuse.js": "^7.1.0",
    "leaflet": "^1.9.4",
    "marked": "^17.0.5",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.5"
  }
}
